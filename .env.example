# Environment variables for IGRIS_GPT
# Copy this file to `.env` and fill in the secrets as needed.  Do **not** commit the `.env` file to version control.

# API keys for fallback providers
OPENAI_API_KEY=
VASTAI_API_KEY=

# LLM configuration
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=phi4-mini
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
FALLBACK_LLM_PROVIDER=openai
FALLBACK_LLM_MODEL=gpt-4o-mini

# Behaviour toggles
AUTO_PUSH=false
AUTO_COMMIT=false

# Workspace configuration
WORKSPACE_ROOT=./workspace
PROJECT_ROOT=./project