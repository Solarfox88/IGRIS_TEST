# IGRIS_GPT Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Server
IGRIS_HOST=0.0.0.0
IGRIS_PORT=7778

# Project root — the directory IGRIS manages
PROJECT_ROOT=.
WORKSPACE_ROOT=.

# Local LLM (Ollama)
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=phi4-mini
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434

# Fallback LLM (OpenAI) — optional
FALLBACK_LLM_PROVIDER=openai
FALLBACK_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# VAST.ai — optional
VASTAI_API_KEY=
VASTAI_MODEL=deepseek-r1:32b
VASTAI_FALLBACK_MODEL=qwen2.5-coder:7b
VASTAI_AUTO_PROVISION=false
VASTAI_REQUIRE_APPROVAL=true
VASTAI_MAX_HOURLY_COST=0.50
VASTAI_MODE=on_demand
VAST_API_KEY=

# Safety
AUTO_COMMIT=false
AUTO_PUSH=false
